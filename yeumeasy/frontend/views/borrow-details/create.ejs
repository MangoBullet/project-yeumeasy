<%- include('../partials/header') %>
<section class="card">
  <h1>Create Borrow Detail</h1>
  <form id="createForm">
    <select name="borrow_id" id="borrowSelect" required></select>
    <select name="equipment_id" id="equipmentSelect" required></select>
    <input type="number" name="amount" min="1" value="1" required />
    <input type="number" name="returned_amount" min="0" value="0" required />
    <div class="flex">
      <button class="btn btn-success" type="submit">Save</button>
      <a class="btn btn-gray" href="/borrow-details">Cancel</a>
    </div>
  </form>
</section>
<script>
const API = '<%= apiBaseUrl %>';
async function init() {
  const [borrowRes, equipmentRes] = await Promise.all([
    fetch(`${API}/borrows?page=1&pageSize=1000`),
    fetch(`${API}/equipment?page=1&pageSize=1000`)
  ]);
  const borrows = await borrowRes.json();
  const equipment = await equipmentRes.json();
  document.getElementById('borrowSelect').innerHTML = borrows.data.map(b => `<option value="${b.id}">Borrow #${b.id}</option>`).join('');
  document.getElementById('equipmentSelect').innerHTML = equipment.data.map(e => `<option value="${e.id}">${e.equipment_name}</option>`).join('');
}
init();
document.getElementById('createForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const payload = Object.fromEntries(new FormData(e.target).entries());
  payload.borrow_id = Number(payload.borrow_id);
  payload.equipment_id = Number(payload.equipment_id);
  payload.amount = Number(payload.amount);
  payload.returned_amount = Number(payload.returned_amount);
  const res = await fetch(`${API}/borrow-details`, {
    method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload)
  });
  if (res.ok) window.location = '/borrow-details'; else alert('Create failed (borrow_id + equipment_id must be unique)');
});
</script>
<%- include('../partials/footer') %>
