<%- include('../partials/header') %>
<section class="card">
  <h1>แดชบอร์ด</h1>
  <p class="small">ภาพรวมของระบบที่ดึงข้อมูลจาก Backend API</p>
</section>

<section class="grid" id="summaryGrid"></section>

<section class="card">
  <h2>กิจกรรมล่าสุด (รายการยืม 5 รายการล่าสุด)</h2>
  <table>
    <thead><tr><th>รหัส</th><th>ผู้ใช้งาน</th><th>วันที่ยืม</th><th>วันครบกำหนด</th><th>สถานะ</th></tr></thead>
    <tbody id="recentRows"></tbody>
  </table>
</section>

<script>
const API = '<%= apiBaseUrl %>';
(async () => {
  const res = await fetch(`${API}/dashboard`);
  const j = await res.json();
  const d = j.data;

  const summary = [
    { label: 'Total Users', value: d.totalUsers },
    { label: 'Total Equipment', value: d.totalEquipment },
    { label: 'Active Borrow', value: d.totalActiveBorrow },
    { label: 'Overdue', value: d.totalOverdue }
  ];

  document.getElementById('summaryGrid').innerHTML = summary.map(s => `
    <article class="card">
      <div class="small">${s.label}</div>
      <h2>${s.value}</h2>
    </article>
  `).join('');

  document.getElementById('recentRows').innerHTML = d.latestBorrows.map(x => `
    <tr>
      <td>${x.id}</td>
      <td>${x.user ? x.user.full_name : x.user_id}</td>
      <td>${x.borrow_date}</td>
      <td>${x.due_date}</td>
      <td>${x.borrow_status}</td>
    </tr>
  `).join('');
})();
</script>
<%- include('../partials/footer') %>
