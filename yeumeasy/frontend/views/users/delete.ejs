<%- include('../partials/header') %>
<section class="card">
  <h1>Delete User</h1>
  <p class="small" id="target">Loading user...</p>
  <div class="flex">
    <button class="btn btn-danger" id="deleteBtn">Confirm Delete</button>
    <a class="btn btn-gray" href="/users">Cancel</a>
  </div>
</section>
<script>
const API = '<%= apiBaseUrl %>';
const id = window.location.pathname.split('/')[2];
(async () => {
  const res = await fetch(`${API}/users/${id}`);
  const json = await res.json();
  document.getElementById('target').textContent = `${json.data.full_name} (${json.data.student_id || '-'})`;
})();
document.getElementById('deleteBtn').addEventListener('click', async () => {
  const res = await fetch(`${API}/users/${id}`, { method: 'DELETE' });
  if (res.ok) window.location = '/users';
  else alert('Delete failed');
});
</script>
<%- include('../partials/footer') %>